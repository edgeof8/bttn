javascript:(async()=>{ const SEP="\n\n"+"━".repeat(40)+"\n\n"; const h=location.hostname; let out=""; function nodeToText(el){ let t=""; el.childNodes.forEach(n=>{ if(n.nodeType===3)t+=n.textContent; else if(n.nodeType===1){ const tag=n.tagName; if(["BR","P","DIV","LI","H1","H2","H3","H4","H5","H6","TR"].includes(tag))t+="\n"; t+=nodeToText(n); if(["P","DIV","LI","TR"].includes(tag))t+="\n"; } }); return t; } function isJustTimestamp(txt){ return /^\s*(Human|Model|Assistant|User)\s+\d+:\d+\s*(AM|PM)?\s*$/.test(txt); } if(h.includes("claude.ai")){ document.querySelectorAll(%27[data-test-render-count]%27).forEach(t=>{ const u=t.querySelector(%27[data-testid="user-message"]%27); const a=t.querySelector(%27.font-claude-response%27); if(u){const txt=Array.from(u.querySelectorAll(%27p.whitespace-pre-wrap%27)).map(p=>p.innerText.trim()).filter(Boolean).join("\n");if(txt)out+="=== Human ===\n"+txt+SEP;} if(a){const txt=Array.from(a.querySelectorAll(%27p.font-claude-response-body%27)).map(p=>p.innerText.trim()).filter(Boolean).join("\n\n");if(txt)out+="=== Claude ===\n"+txt+SEP;} }); } else if(h.includes("aistudio.google")){ const sc=document.querySelector(%27[data-autoscroll-container]%27)||document.documentElement; const sv=sc.scrollTop; sc.scrollTop=0; await new Promise(r=>setTimeout(r,500)); const mc=document.querySelector(%27ms-prompt-editor .view-lines%27); if(mc){const t=mc.innerText.trim();if(t)out+="=== Initial Prompt ===\n"+t+SEP;} sc.scrollTop=sv; document.querySelectorAll(%27ms-chat-turn%27).forEach(t=>{ const isUser=!!t.querySelector(%27.user-prompt-container%27); const role=isUser?%27Human%27:%27Model%27; const tc=t.querySelector(%27.turn-content%27); if(tc){ const cl=tc.cloneNode(true); cl.querySelectorAll(%27.thoughts-container,.model-thoughts,[class*="thought"],[class*="expand"],.mat-expansion-panel%27).forEach(e=>e.remove()); const txt=cl.innerText.replace(/Expand to view model thoughts/g,%27%27).replace(/chevron_right/g,%27%27).replace(/^(Human|Model)\s+\d+:\d+\s*(AM|PM)?\s*\n/,%27%27).trim(); if(txt&&!isJustTimestamp(txt))out+=`=== ${role} ===\n${txt}${SEP}`; } }); } else if(h.includes("chatgpt.com")||h.includes("chat.openai")){ document.querySelectorAll(%27div[data-message-author-role]%27).forEach(m=>{ const role=m.getAttribute(%27data-message-author-role%27); const label=role===%27user%27?%27Human%27:%27Assistant%27; const txt=nodeToText(m).replace(/\n{3,}/g,%27\n\n%27).trim(); if(txt)out+=`=== ${label} ===\n${txt}${SEP}`; }); } out=out.trimEnd().replace(/━+\s*$/,%27%27).trimEnd(); if(out)await navigator.clipboard.writeText(out); })();
